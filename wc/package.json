{
	"name": "zesty-wc",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n lib,web,convex -c blue,green,magenta \"vite build --config vite.lib.config.ts --watch\" \"vite --port 5174\" \"convex dev\"",
		"dev:lib": "vite build --config vite.lib.config.ts --watch",
		"dev:web": "vite",
		"dev:convex": "convex dev",
		"build": "npm run build:lib && tsc --noEmit -p tsconfig.app.json && vite build",
		"build:lib": "tsc --noEmit -p tsconfig.json && vite build --config vite.lib.config.ts",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"typecheck:app": "tsc --noEmit -p tsconfig.app.json"
	},
	"dependencies": {
		"@auth/core": "0.41.1",
		"@convex-dev/auth": "^0.0.94",
		"@monaco-editor/react": "^4.7.0",
		"@phosphor-icons/react": "^2.1.10",
		"atomico": "^2.1.0",
		"convex": "^1.41.0",
		"datass": "^2.1.2",
		"highlight.js": "^11.11.1",
		"lowlight": "^3.3.0",
		"react": "^19",
		"react-dom": "^19",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0",
		"wouter": "^3.10.0"
	},
	"devDependencies": {
		"@types/hast": "^3.0.4",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.7.0",
		"concurrently": "^10.0.3",
		"monaco-editor": "^0.55.1",
		"typescript": "^5.7.3",
		"vite": "^6.0.0"
	}
}
